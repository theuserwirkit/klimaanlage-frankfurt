# Öffentliche URL der Seite (für Open Graph Meta-Tags)
NEXT_PUBLIC_SITE_URL=https://klima-mieten-frankfurt.com

# Resend API Key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# E-Mail-Adresse, an die Anfragen gesendet werden
INQUIRY_EMAIL_TO=bp@wirkung-group.de

# Absender-Adresse (muss bei Resend verifiziert sein)
INQUIRY_EMAIL_FROM=Klimaanlage Frankfurt <anfragen@ihre-domain.de>
