# Öffentliche URL der Seite (für Open Graph Meta-Tags)
NEXT_PUBLIC_SITE_URL=https://klima-mieten-frankfurt.com

# Resend API Key — https://resend.com/api-keys (Pflicht für E-Mail-Versand!)
RESEND_API_KEY=re_xxxxxxxxxxxx

# E-Mail-Adresse, an die Anfragen gesendet werden
INQUIRY_EMAIL_TO=bp@wirkung-digital.de

# Absender-Adresse (Domain muss bei Resend verifiziert sein, z. B. wirkung-group.de)
INQUIRY_EMAIL_FROM=Klimaanlage Frankfurt <anfragen@wirkung-group.de>
